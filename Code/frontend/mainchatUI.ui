      </sizepolicy>
     </property>
     <property name="styleSheet">
      <string notr="true">/* Làm đẹp Header */
QLabel#lbl_chat_title {
    font-weight: bold;
    font-size: 14px;
    color: #ffffff;
}

/* Xóa viền của vùng cuộn tin nhắn */
QScrollArea#scroll_chat_history {
    border: none;
    background-color: #16191D; /* Màu nền vùng chat (tối) */
}

/* Làm mượt dải nút chức năng (Sticker, Ảnh, Cam) */
QPushButton#btn_sticker, QPushButton#btn_image, QPushButton#btn_camera, QPushButton#btn_search_chat, QPushButton#btn_toggle_info {
    border: none;
    background-color: transparent;
    padding: 5px;
}
QPushButton#btn_sticker:hover, QPushButton#btn_image:hover, QPushButton#btn_camera:hover, QPushButton#btn_search_chat:hover, QPushButton#btn_toggle_info:hover {
    background-color: rgba(255, 255, 255, 0.1); /* Sáng nhẹ khi di chuột vào */
    border-radius: 5px;
}

/* Làm đẹp ô gõ tin nhắn */
QLineEdit#txt_input_message {
    border: 1px solid #333333;
    border-radius: 15px;
    padding: 6px 12px;
    background-color: #2d2d2d;
    color: #ffffff;
}

QLineEdit#txt_input_message:focus {
    border: 1px solid #3498db; /* Viền đổi sang màu xanh dương để người dùng biết đang gõ */
}
/* Làm đẹp nút Gửi */
QPushButton#btn_send {
    border: none;
    background-color: transparent;
    color: white;
    padding: 6px 15px;
    border-radius: 15px;
    font-weight: bold;
}
QPushButton#btn_send:hover {
    background-color: rgba(255, 255, 255, 0.1);
}</string>
     </property>
